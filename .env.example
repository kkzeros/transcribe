# 通义听悟转写 skill 所需环境变量
# 将此文件复制为 .env 并填入真实值，放在 skill 根目录下（与 SKILL.md 同级）

# 阿里云 RAM 访问密钥（需要 OSS 读写权限 + 通义听悟调用权限）
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# 通义听悟 AppKey（在 https://tingwu.console.aliyun.com 项目管理中查看）
TINGWU_APP_KEY=

# 通义听悟地域（默认 cn-beijing，按实际开通地域填写）
TINGWU_REGION=cn-beijing

# OSS Bucket 名称（用于中转音视频文件，需公共读权限）
OSS_BUCKET=

# OSS Endpoint（格式：oss-{region}.aliyuncs.com，与 Bucket 地域一致）
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# 转写结果父目录；最终输出会保存到 <此目录>/transcribe-results
# 支持绝对路径、~ 路径、相对 skill 根目录的路径。
# 若留空或路径不存在，默认按安装位置推导：
#   ~/.agents/skills/transcribe      -> ~/.agents/transcribe-results
#   ~/.claude/skills/transcribe      -> ~/.claude/transcribe-results
#   ~/.openclaw/skills/transcribe    -> ~/.openclaw/transcribe-results
TRANSCRIBE_OUTPUT_PARENT_DIR=
